{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lewontin-paradox.invalid/schemas/tier3_run_record.schema.json",
  "title": "Tier 3 runnable record supplement",
  "description": "Fields required by runners in addition to the frozen scientific manifest contract. This record is generated and checksum-locked with the manifest; it never embeds payloads or credentials.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "dataset_id", "reference_assembly", "annotation_provenance", "variation_source",
    "callability", "pansn", "sample_policy", "modality", "expected_observable",
    "eligibility", "tools", "expected_outputs"
  ],
  "properties": {
    "dataset_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
    "reference_assembly": {
      "type": "object", "additionalProperties": false,
      "required": ["accession_version", "fasta_sha256", "fai_sha256", "dictionary_sha256"],
      "properties": {
        "accession_version": {"pattern": "^(GC[AF]_[0-9]+|[A-Za-z][A-Za-z0-9_-]*)\\.[0-9]+"},
        "fasta_sha256": {"pattern": "^[0-9a-f]{64}$"},
        "fai_sha256": {"pattern": "^[0-9a-f]{64}$"},
        "dictionary_sha256": {"pattern": "^[0-9a-f]{64}$"}
      }
    },
    "annotation_provenance": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object", "additionalProperties": false,
          "required": ["provider", "release", "assembly_accession_version", "gff_sha256", "sequence_regions_sha256", "contig_mapping_sha256", "genetic_code", "status", "audit_passed"],
          "properties": {
            "provider": {"type": "string", "minLength": 1},
            "release": {"type": "string", "minLength": 1},
            "assembly_accession_version": {"type": "string", "minLength": 3},
            "gff_sha256": {"pattern": "^[0-9a-f]{64}$"},
            "sequence_regions_sha256": {"pattern": "^[0-9a-f]{64}$"},
            "contig_mapping_sha256": {"pattern": "^[0-9a-f]{64}$"},
            "genetic_code": {"type": "integer", "minimum": 1, "maximum": 33},
            "status": {"enum": ["native", "projected", "predicted"]},
            "audit_passed": {"type": "boolean"}
          }
        }
      ]
    },
    "variation_source": {
      "type": "object", "additionalProperties": false,
      "required": ["kind", "sha256"],
      "properties": {
        "kind": {"enum": ["normalized_bcf", "wfmash_paf", "none"]},
        "sha256": {"oneOf": [{"pattern": "^[0-9a-f]{64}$"}, {"type": "null"}]}
      }
    },
    "callability": {
      "type": "object", "additionalProperties": false,
      "required": ["kind", "semantics", "sha256"],
      "properties": {
        "kind": {"enum": ["all_sites_vcf", "gvcf", "cohort_callable_mask", "h1_reference_alignable_mask", "unavailable"]},
        "semantics": {"type": "string", "minLength": 1},
        "sha256": {"oneOf": [{"pattern": "^[0-9a-f]{64}$"}, {"type": "null"}]}
      }
    },
    "pansn": {
      "type": "object", "additionalProperties": false,
      "required": ["reference", "query"],
      "properties": {
        "reference": {"pattern": "^[^#\\s]+#[0-9]+#[^#\\s]+$"},
        "query": {"pattern": "^[^#\\s]+#[0-9]+#[^#\\s]+$"}
      }
    },
    "sample_policy": {
      "type": "object", "additionalProperties": false,
      "required": ["design", "sample_list_sha256", "ploidy", "nominal_chromosomes", "minimum_called_chromosomes"],
      "properties": {
        "design": {"enum": ["wild_diploid", "inbred_lines_haploidized", "single_diploid_individual", "unavailable"]},
        "sample_list_sha256": {"oneOf": [{"pattern": "^[0-9a-f]{64}$"}, {"type": "null"}]},
        "ploidy": {"oneOf": [{"enum": [1, 2]}, {"type": "null"}]},
        "nominal_chromosomes": {"oneOf": [{"type": "integer", "minimum": 2}, {"type": "null"}]},
        "minimum_called_chromosomes": {"oneOf": [{"type": "integer", "minimum": 2}, {"type": "null"}]}
      }
    },
    "modality": {"enum": ["deposited_exact_reference_variants_plus_mask", "direct_wfmash_extended_cigar", "composition_only"]},
    "expected_observable": {"enum": ["whole_genome_gc", "gc3", "population_pi", "individual_snv_heterozygosity", "pi_S_over_pi_W"]},
    "eligibility": {
      "type": "object", "additionalProperties": false,
      "required": ["wfmash", "impg"],
      "properties": {
        "wfmash": {"type": "boolean"},
        "impg": {"const": false}
      }
    },
    "tools": {
      "type": "object", "additionalProperties": false,
      "required": ["wfmash_commit", "wfmash_store_path", "impg_commit", "impg_store_path"],
      "properties": {
        "wfmash_commit": {"const": "e040aa10e87cab44ed5a4db005e784be62b0bd21"},
        "wfmash_store_path": {"pattern": "^/gnu/store/[0-9a-z]{32}-[^/]+$"},
        "impg_commit": {"const": "101df81eb28a809c8fac97d297acd9fcfbbfa048"},
        "impg_store_path": {"type": "null"}
      }
    },
    "expected_outputs": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z0-9][A-Za-z0-9._/-]+$"}
    }
  },
  "allOf": [
    {
      "if": {"properties": {"expected_observable": {"enum": ["gc3", "pi_S_over_pi_W"]}}},
      "then": {
        "properties": {
          "annotation_provenance": {
            "type": "object",
            "properties": {"status": {"const": "native"}, "audit_passed": {"const": true}}
          }
        }
      }
    },
    {
      "if": {"properties": {"variation_source": {"properties": {"kind": {"enum": ["normalized_bcf", "wfmash_paf"]}}}}},
      "then": {"properties": {"callability": {"properties": {"kind": {"not": {"const": "unavailable"}}, "sha256": {"pattern": "^[0-9a-f]{64}$"}}}}}
    }
  ]
}
