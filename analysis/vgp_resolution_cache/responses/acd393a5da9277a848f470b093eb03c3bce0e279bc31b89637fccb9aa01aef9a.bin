{"reports":[{"accession":"GCF_036321535.1", "current_accession":"GCF_036321535.1", "paired_accession":"GCA_036321535.1", "source_database":"SOURCE_DATABASE_REFSEQ", "organism":{"tax_id":9838, "organism_name":"Camelus dromedarius", "common_name":"Arabian camel", "infraspecific_names":{"isolate":"mCamDro1", "sex":"male"}}, "assembly_info":{"assembly_level":"Chromosome", "assembly_status":"current", "paired_assembly":{"accession":"GCA_036321535.1", "status":"current", "only_genbank":"chromosome MT", "refseq_genbank_are_different":true, "differences":"Removed chromosome MT"}, "assembly_name":"mCamDro1.pat", "assembly_type":"haploid", "bioproject_lineage":[{"bioprojects":[{"accession":"PRJNA1064426", "title":"Camelus dromedarius (Arabian camel) genome, mCamDro1, paternal haplotype", "parent_accessions":["PRJNA1068118"]}, {"accession":"PRJNA1068118", "title":"Camelus dromedarius (Arabian camel) genome, mCamDro1", "parent_accessions":["PRJNA489243"]}, {"accession":"PRJNA489243", "title":"Vertebrate Genomes Project", "parent_accessions":["PRJNA533106"]}, {"accession":"PRJNA533106", "title":"Earth BioGenome Project (EBP)"}]}], "bioproject_accession":"PRJNA1064426", "release_date":"2024-01-31", "submitter":"Vertebrate Genomes Project", "refseq_category":"reference genome", "sequencing_tech":"PacBio Sequel II HiFi; Dovetail OmniC", "assembly_method":"Hifiasm + Trio-binning v. 0.16.1 + galaxy4; yahs v. 1.2a.2", "biosample":{"accession":"SAMN39296380", "last_updated":"2024-07-30T09:26:21.607", "publication_date":"2024-01-08T00:00:00.000", "submission_date":"2024-01-08T13:22:04.413", "sample_ids":[{"label":"Sample name", "value":"Animal sample from Camelus dromedarius (Arabian camel) for VGP reference genome, mCamDro1"}, {"db":"SRA", "value":"SRS22165637"}], "description":{"title":"Animal sample from Camelus dromedarius (Arabian camel) for VGP genome, mCamDro1", "organism":{"tax_id":9838, "organism_name":"Camelus dromedarius"}, "comment":"The Arabian camel (Camelus dromedarius ) is a one-humped camel species found in the Middle East and North Africa. It is remarkable for its adaptations to arid environments and has been integral to human societies in these regions. This sample (mCamDro1) is from a male bred at Mr. Shabat bin Saqar Al-Muraikhi camel breeding farm, in Qatar. Samples were also obtained from parents (father mCamDro2 and mother mCamDro3). These samples were collected and coordinated by Farooq Omar Al-Ajli (Katara Biodiversity Genomes Program), to create trio-based high-quality assemblies of the maternal and paternal haplotypes for the Vertebrate Genomes Project (VGP) and Qatar Biodiversity Genomes Project (QBGP). Sequencing was done at the Vertebrate Genomes Lab (VGL) at Rockefeller University, led by Olivier Fedrigo and Erich D. Jarvis. Genome assembly was conducted at Sidra Medicine by Farooq Omar Al-Ajli and Khalid A. Fakhro in collaboration with VGL."}, "owner":{"name":"G10K", "contacts":[{}]}, "models":["Model organism or animal"], "package":"Model.organism.animal.1.0", "attributes":[{"name":"isolate", "value":"mCamDro1"}, {"name":"age", "value":"1 year"}, {"name":"dev_stage", "value":"adult"}, {"name":"collection_date", "value":"2022-02-17"}, {"name":"geo_loc_name", "value":"Qatar: Mr. Shabat bin Saqar Al-Muraikhi camel breeding farm"}, {"name":"sex", "value":"male"}, {"name":"tissue", "value":"blood"}, {"name":"collected_by", "value":"Rasheed Hashim, Farooq Omar Al-Ajli"}, {"name":"lat_lon", "value":"25.27881495 N 51.50256842 E"}, {"name":"store_cond", "value":"-80oC"}, {"name":"treatment", "value":"K2EDTA frozen"}], "status":{"status":"live", "when":"2024-01-08T13:22:04.414"}, "age":"1 year", "collected_by":"Rasheed Hashim, Farooq Omar Al-Ajli", "collection_date":"2022-02-17", "dev_stage":"adult", "geo_loc_name":"Qatar: Mr. Shabat bin Saqar Al-Muraikhi camel breeding farm", "isolate":"mCamDro1", "lat_lon":"25.27881495 N 51.50256842 E", "sex":"male", "tissue":"blood"}, "blast_url":"https://blast.ncbi.nlm.nih.gov/Blast.cgi