{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/lewontin-paradox/vgp-10-pilot-output-v1.json",
  "title": "VGP ten-pair pilot immutable output index",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "selection_id",
    "orientation",
    "pair_provenance",
    "environment",
    "mapping",
    "impg",
    "variants",
    "mask",
    "consensus",
    "psmc",
    "confidence",
    "annotation",
    "telemetry",
    "disposition"
  ],
  "properties": {
    "schema_version": {"const": "vgp-10-pilot-output-v1"},
    "run_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"},
    "selection_id": {"type": "string", "pattern": "^P(0[1-9]|10)$"},
    "orientation": {"const": "H1_reference_H2_query"},
    "pair_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["biosample", "individual_or_isolate", "h1_accession_version", "h2_accession_version", "h1_sha256", "h2_sha256", "design_manifest_sha256"],
      "properties": {
        "biosample": {"type": "string", "minLength": 1},
        "individual_or_isolate": {"type": "string", "minLength": 1},
        "h1_accession_version": {"type": "string", "pattern": "^GC[AF]_[0-9]+\\.[0-9]+$"},
        "h2_accession_version": {"type": "string", "pattern": "^GC[AF]_[0-9]+\\.[0-9]+$"},
        "h1_sha256": {"$ref": "#/$defs/sha256"},
        "h2_sha256": {"$ref": "#/$defs/sha256"},
        "design_manifest_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["channel_commit", "manifest_sha256", "derivation", "profile", "closure_sha256", "executables", "source_identities"],
      "properties": {
        "channel_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "manifest_sha256": {"$ref": "#/$defs/sha256"},
        "derivation": {"type": "string", "pattern": "^/gnu/store/.+\\.drv$"},
        "profile": {"type": "string", "pattern": "^/gnu/store/"},
        "closure_sha256": {"$ref": "#/$defs/sha256"},
        "executables": {"type": "array", "minItems": 8, "items": {"$ref": "#/$defs/digestPath"}},
        "source_identities": {"type": "object", "required": ["sweepga", "impg", "psmc"]}
      }
    },
    "mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["whole_h1_fasta", "whole_h2_fasta", "required_option", "scaffold_jump", "paf", "maximum_query_overlap_depth", "maximum_target_overlap_depth"],
      "properties": {
        "whole_h1_fasta": {"const": true},
        "whole_h2_fasta": {"const": true},
        "required_option": {"const": "--num-mappings 1:1"},
        "scaffold_jump": {"const": 0},
        "paf": {"$ref": "#/$defs/digestPath"},
        "maximum_query_overlap_depth": {"const": 1},
        "maximum_target_overlap_depth": {"const": 1}
      }
    },
    "impg": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage_order", "exact_paf_sha256", "index", "native_partitions", "selected_native_partitions", "regional_vcfs", "laced_vcf"],
      "properties": {
        "stage_order": {"const": ["index", "partition", "query", "lace"]},
        "exact_paf_sha256": {"$ref": "#/$defs/sha256"},
        "index": {"$ref": "#/$defs/digestPath"},
        "native_partitions": {"$ref": "#/$defs/digestPath"},
        "selected_native_partitions": {"$ref": "#/$defs/digestPath"},
        "regional_vcfs": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/digestPath"}},
        "laced_vcf": {"$ref": "#/$defs/digestPath"}
      }
    },
    "variants": {
      "type": "object",
      "additionalProperties": false,
      "required": ["normalization_reference", "exact_deduplication", "vcf_gz", "tbi", "bcf", "csi", "h1_ref_mismatches", "h2_reconstruction_failures"],
      "properties": {
        "normalization_reference": {"const": "exact_H1"},
        "exact_deduplication": {"const": true},
        "vcf_gz": {"$ref": "#/$defs/digestPath"},
        "tbi": {"$ref": "#/$defs/digestPath"},
        "bcf": {"$ref": "#/$defs/digestPath"},
        "csi": {"$ref": "#/$defs/digestPath"},
        "h1_ref_mismatches": {"const": 0},
        "h2_reconstruction_failures": {"const": 0}
      }
    },
    "mask": {
      "type": "object",
      "additionalProperties": false,
      "required": ["coordinate_system", "universe_bp", "callable_bp", "callable_fraction", "callable_bed", "reason_order", "reason_coded_complement", "accounting_discrepancy_bp"],
      "properties": {
        "coordinate_system": {"const": "H1_zero_based_half_open"},
        "universe_bp": {"type": "integer", "minimum": 1},
        "callable_bp": {"type": "integer", "minimum": 0},
        "callable_fraction": {"type": "number", "minimum": 0, "maximum": 1},
        "callable_bed": {"$ref": "#/$defs/digestPath"},
        "reason_order": {"type": "array", "minItems": 13, "uniqueItems": true, "items": {"type": "string"}},
        "reason_coded_complement": {"type": "array", "minItems": 13, "items": {"$ref": "#/$defs/reasonBed"}},
        "accounting_discrepancy_bp": {"const": 0}
      }
    },
    "consensus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fasta", "psmcfa", "masked_base_encoding", "heterozygous_snp_encoding", "primary_indel_flank_bp", "non_callable_bases_encoded_homozygous_reference"],
      "properties": {
        "fasta": {"$ref": "#/$defs/digestPath"},
        "psmcfa": {"$ref": "#/$defs/digestPath"},
        "masked_base_encoding": {"const": "N"},
        "heterozygous_snp_encoding": {"const": "IUPAC"},
        "primary_indel_flank_bp": {"const": 10},
        "non_callable_bases_encoded_homozygous_reference": {"const": 0}
      }
    },
    "psmc": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unscaled", "bootstrap_attempts", "bootstrap_units", "primary_block_bp", "sensitivity_block_bp", "crosses_contig_boundary", "crosses_mask_boundary", "scenario_outputs"],
      "properties": {
        "unscaled": {"$ref": "#/$defs/digestPath"},
        "bootstrap_attempts": {"type": "integer", "minimum": 100},
        "bootstrap_units": {"$ref": "#/$defs/digestPath"},
        "primary_block_bp": {"const": 5000000},
        "sensitivity_block_bp": {"const": [1000000, 10000000]},
        "crosses_contig_boundary": {"const": false},
        "crosses_mask_boundary": {"const": false},
        "scenario_outputs": {"type": "array", "items": {"$ref": "#/$defs/digestPath"}}
      }
    },
    "confidence": {
      "type": "object",
      "required": ["tier", "read_technology", "qv", "completeness", "duplication_collapse", "pair_provenance", "long_range_phasing", "callability", "validation"],
      "properties": {"tier": {"enum": ["A", "B", "C", "X"]}}
    },
    "annotation": {
      "oneOf": [
        {"type": "object", "required": ["status", "core_blocked"], "properties": {"status": {"const": "not_available"}, "core_blocked": {"const": false}}},
        {
          "type": "object",
          "required": ["status", "assembly_accession_version", "annotation_accession_version", "dictionary_equal", "partitions"],
          "properties": {
            "status": {"enum": ["exact_native", "validated_liftover"]},
            "assembly_accession_version": {"type": "string"},
            "annotation_accession_version": {"type": "string"},
            "dictionary_equal": {"const": true},
            "partitions": {
              "type": "array",
              "items": {"enum": ["CDS", "fourfold", "nonsynonymous", "synonymous", "WS", "SW", "GC3"]}
            }
          }
        }
      ]
    },
    "telemetry": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/digestPath"}},
    "disposition": {"enum": ["PASS", "FAIL", "SENSITIVITY_ONLY", "NOT_RUN"]}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "digestPath": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "size_bytes"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha256"},
        "size_bytes": {"type": "integer", "minimum": 0}
      }
    },
    "reasonBed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "size_bytes", "reason", "bp"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha256"},
        "size_bytes": {"type": "integer", "minimum": 0},
        "reason": {"type": "string"},
        "bp": {"type": "integer", "minimum": 0}
      }
    }
  }
}
